generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Developpeur {
  id            String   @id @default(cuid())
  nom           String
  specialite    String
  image         String?
  lienPortfolio String?
  outils        Outil[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Outil {
  id            String      @id @default(cuid())
  nom           String
  developpeur   Developpeur @relation(fields: [developpeurId], references: [id], onDelete: Cascade)
  developpeurId String
}