generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

model Developpeur {
  id         String   @id @default(cuid())
  nom        String
  prenom     String
  email      String   @unique
  titre      String
  competences Competence[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Competence {
  id            String      @id @default(cuid())
  nom           String
  developpeur   Developpeur @relation(fields: [developpeurId], references: [id], onDelete: Cascade)
  developpeurId String
}